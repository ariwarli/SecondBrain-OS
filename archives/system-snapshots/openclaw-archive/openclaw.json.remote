{
  "gateway": {
    "port": 39217,
    "bind": "loopback",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "mode": "local"
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        },
        "-1003344368011": {
          "requireMention": false
        }
      },
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "allowFrom": [
        "163335047"
      ],
      "groupAllowFrom": [
        "163335047"
      ],
      "execApprovals": {
        "enabled": false
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-2.5-flash",
        "fallbacks": [
          "google/gemini-2.5-pro",
          "mistral/mistral-small-latest",
          "deepseek/deepseek-chat"
        ]
      },
      "workspace": "/home/openclaw/banirisset",
      "sandbox": {
        "mode": "all",
        "backend": "docker",
        "workspaceAccess": "rw",
        "scope": "session",
        "docker": {
          "env": {
            "OPENCLAW_GATEWAY_TOKEN": "${OPENCLAW_GATEWAY_TOKEN}",
            "TELEGRAM_BOT_TOKEN": "${TELEGRAM_BOT_TOKEN}",
            "GEMINI_API_KEY": "${GEMINI_API_KEY}",
            "MISTRAL_API_KEY": "${MISTRAL_API_KEY}",
            "DEEPSEEK_API_KEY": "${DEEPSEEK_API_KEY}"
          }
        }
      },
      "subagents": {
        "allowAgents": [
          "reed-builder",
          "reed-researcher",
          "reed-archivist"
        ],
        "requireAgentId": true,
        "maxConcurrent": 3,
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 3,
        "archiveAfterMinutes": 30
      }
    },
    "list": [
      {
        "id": "reed-archivist",
        "workspace": "/home/openclaw/.openclaw/workspaces/reed-archivist"
      },
      {
        "id": "reed-builder",
        "workspace": "/home/openclaw/.openclaw/workspaces/reed-builder"
      },
      {
        "id": "reed-researcher",
        "workspace": "/home/openclaw/.openclaw/workspaces/reed-researcher"
      }
    ]
  },
  "models": {
    "mode": "replace",
    "providers": {
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "api": "openai-completions",
        "apiKey": "${GEMINI_API_KEY}",
        "models": [
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash",
            "contextWindow": 1048576,
            "maxTokens": 8192,
            "input": [
              "text",
              "image"
            ]
          },
          {
            "id": "gemini-2.5-pro",
            "name": "Gemini 2.5 Pro",
            "contextWindow": 2097152,
            "maxTokens": 8192,
            "input": [
              "text",
              "image"
            ]
          }
        ]
      },
      "mistral": {
        "baseUrl": "https://api.mistral.ai/v1",
        "api": "openai-completions",
        "apiKey": "${MISTRAL_API_KEY}",
        "models": [
          {
            "id": "mistral-small-latest",
            "name": "Mistral Small Latest",
            "contextWindow": 128000,
            "maxTokens": 4096,
            "input": [
              "text"
            ]
          }
        ]
      },
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "api": "openai-completions",
        "apiKey": "${DEEPSEEK_API_KEY}",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat",
            "contextWindow": 128000,
            "maxTokens": 8192,
            "input": [
              "text"
            ]
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek Reasoner",
            "contextWindow": 128000,
            "maxTokens": 8192,
            "input": [
              "text"
            ]
          }
        ]
      }
    }
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "scope": {
          "default": "allow",
          "rules": [
            {
              "action": "deny",
              "match": {
                "chatType": "group"
              }
            }
          ]
        },
        "models": [
          {
            "provider": "groq"
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "google": {
        "enabled": true,
        "config": {
          "webSearch": {
            "model": "gemini-2.5-flash",
            "apiKey": "${GEMINI_API_KEY}"
          }
        }
      },
      "mistral": {
        "enabled": true
      },
      "deepseek": {
        "enabled": true
      }
    }
  },
  "approvals": {
    "exec": {
      "enabled": true
    },
    "plugin": {
      "enabled": false
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.8",
    "lastTouchedAt": "2026-04-10T17:21:16.000Z"
  }
}
